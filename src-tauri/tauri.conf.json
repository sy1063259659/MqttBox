{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MqttBox",
  "version": "0.1.0",
  "identifier": "com.mqttbox.app",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MqttBox",
        "width": 1480,
        "height": 920,
        "minWidth": 1200,
        "minHeight": 760,
        "decorations": false,
        "shadow": true,
        "transparent": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
