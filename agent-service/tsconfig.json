{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "rootDir": "..",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@agent-contracts": ["../packages/agent-contracts/src/index.ts"],
      "@agent-contracts/*": ["../packages/agent-contracts/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
